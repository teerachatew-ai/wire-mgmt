@echo off
chcp 65001 >nul
title ตั้งค่าเปิดอัตโนมัติ - ตัวช่วยอ่านบัตร
cd /d %~dp0

if not exist "node_modules\pcsclite" (
    echo [!] ยังไม่ได้ติดตั้ง — กรุณาดับเบิลคลิก "1-ติดตั้งครั้งแรก.bat" ก่อน
    echo.
    pause
    exit /b 1
)

set "STARTUP=%APPDATA%\Microsoft\Windows\Start Menu\Programs\Startup"
set "LAUNCHER=%STARTUP%\ตัวช่วยอ่านบัตรประชาชน (เปิดอัตโนมัติ).bat"

(
    echo @echo off
    echo chcp 65001 ^>nul
    echo cd /d "%~dp0"
    echo start "" /min "2-เปิดตัวช่วยอ่านบัตร.bat"
) > "%LAUNCHER%"

echo ==================================================
echo   ตั้งค่าเรียบร้อยแล้ว ✅
echo ==================================================
echo.
echo   ต่อไปนี้ตัวช่วยอ่านบัตรจะเปิดเองอัตโนมัติทุกครั้งที่เปิดเครื่อง
echo   (ไม่ต้องดับเบิลคลิก "2-เปิดตัวช่วยอ่านบัตร.bat" อีกแล้ว)
echo.
echo   จะเห็นเป็นหน้าต่างเล็กๆ ย่ออยู่แถบด้านล่างจอ (taskbar)
echo   ถ้าอยากดูสถานะ คลิกที่แถบด้านล่างเพื่อขยายดูได้
echo.
echo   ถ้าอยากยกเลิก ให้รัน "4-ยกเลิกเปิดอัตโนมัติ.bat"
echo ==================================================
echo.
echo กำลังเปิดตัวช่วยให้เลยตอนนี้...
start "" /min "2-เปิดตัวช่วยอ่านบัตร.bat"
echo.
pause
