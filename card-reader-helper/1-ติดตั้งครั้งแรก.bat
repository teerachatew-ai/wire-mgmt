@echo off
chcp 65001 >nul
title ติดตั้งตัวช่วยอ่านบัตร
cd /d %~dp0
echo ==================================================
echo   ติดตั้งตัวช่วยอ่านบัตรประชาชน (ทำครั้งเดียว)
echo ==================================================
echo.

where node >nul 2>&1
if %ERRORLEVEL% NEQ 0 (
    echo [!] ยังไม่ได้ติดตั้ง Node.js
    echo     กรุณาดาวน์โหลดและติดตั้งจาก https://nodejs.org
    echo     แล้วรันไฟล์นี้อีกครั้ง
    echo.
    pause
    exit /b 1
)

echo กำลังติดตั้งส่วนประกอบ... (อาจใช้เวลาสักครู่)
echo.
call npm install
echo.
if exist "node_modules\pcsclite" (
    echo ==================================================
    echo   ติดตั้งเสร็จแล้ว ✅
    echo   ต่อไปดับเบิลคลิกไฟล์ "2-เปิดตัวช่วยอ่านบัตร.bat" เพื่อใช้งาน
    echo ==================================================
) else (
    echo [!] ติดตั้งไม่สมบูรณ์ — โปรดติดต่อผู้ดูแลระบบ
)
echo.
pause
