@echo off
chcp 65001 >nul
title ติดตั้งตัวช่วยอ่านบัตร
cd /d %~dp0
echo ==================================================
echo   ติดตั้งตัวช่วยอ่านบัตรประชาชน (ทำครั้งเดียว)
echo ==================================================
echo.

where node >nul 2>&1
if %ERRORLEVEL% NEQ 0 (
    echo [!] ยังไม่ได้ติดตั้ง Node.js
    echo     กรุณาดาวน์โหลดและติดตั้งจาก https://nodejs.org
    echo     แล้วดับเบิลคลิกไฟล์นี้อีกครั้ง
    echo.
    pause
    exit /b 1
)

echo กำลังติดตั้งส่วนประกอบ... (อาจใช้เวลาสักครู่)
echo.
call npm install
echo.
if not exist "node_modules\pcsclite" (
    echo [!] ติดตั้งไม่สมบูรณ์ — โปรดติดต่อผู้ดูแลระบบ
    echo.
    pause
    exit /b 1
)

echo ==================================================
echo   ติดตั้งส่วนประกอบเสร็จแล้ว ✅
echo   กำลังตั้งค่าให้เปิดอัตโนมัติทุกครั้งที่เปิดเครื่อง...
echo ==================================================
echo.

set "STARTUP=%APPDATA%\Microsoft\Windows\Start Menu\Programs\Startup"
set "LAUNCHER=%STARTUP%\ตัวช่วยอ่านบัตรประชาชน (เปิดอัตโนมัติ).bat"

(
    echo @echo off
    echo chcp 65001 ^>nul
    echo cd /d "%~dp0"
    echo start "" /min "2-เปิดตัวช่วยอ่านบัตร.bat"
) > "%LAUNCHER%"

echo ==================================================
echo   เสร็จสมบูรณ์ ✅✅
echo ==================================================
echo.
echo   ต่อไปนี้ตัวช่วยอ่านบัตรจะเปิดเองอัตโนมัติทุกครั้งที่เปิดเครื่อง
echo   ไม่ต้องมาดับเบิลคลิกไฟล์ไหนอีกเลย — เสียบเครื่องอ่านบัตร
echo   แล้วเข้าเว็บกดปุ่มอ่านบัตรได้เลยตั้งแต่ครั้งถัดไป
echo.
echo   (จะเห็นเป็นหน้าต่างเล็กๆ ย่ออยู่แถบด้านล่างจอ — เปิดทิ้งไว้)
echo   ถ้าอยากยกเลิก ให้รัน "4-ยกเลิกเปิดอัตโนมัติ.bat"
echo ==================================================
echo.
echo กำลังเปิดตัวช่วยให้เลยตอนนี้...
start "" /min "2-เปิดตัวช่วยอ่านบัตร.bat"
echo.
pause
