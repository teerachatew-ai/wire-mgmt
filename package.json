{
  "name": "wire-mgmt-server",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only server/index.ts",
    "build": "tsc",
    "build:cloud": "npm install --prefix client && npm run build --prefix client && tsc",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "iconv-lite": "^0.7.2",
    "localtunnel": "^2.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "sql.js": "^1.12.0"
  },
  "optionalDependencies": {
    "pcsclite": "^1.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
